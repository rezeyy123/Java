import java.util.Scanner;

public class AufgabeD {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        System.out.print("Grenzwert g eingeben: ");
        int g = sc.nextInt();

        double summe = 0;

        for (int i = 1; i <= g; i++) {
            summe += 1.0 / i;
        }

        System.out.println("Summe: " + summe);
        sc.close();
    }
}